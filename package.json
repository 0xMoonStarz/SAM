{
  "name": "sam-cc",
  "version": "1.0.0",
  "description": "SAM - Serialized Abstraction Machine / Super Access Memory for Claude Code. Reduce token usage 3-30x + external memory that survives compaction.",
  "main": "dist/mcp-server/index.js",
  "bin": {
    "sam": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "postinstall": "node dist/cli/index.js postinstall || true",
    "dev": "tsc --watch",
    "test": "node --test dist/tests/*.test.js",
    "start:mcp": "node dist/mcp-server/index.js",
    "prepublishOnly": "npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xMoonStarz/SAM"
  },
  "homepage": "https://github.com/0xMoonStarz/SAM#readme",
  "bugs": {
    "url": "https://github.com/0xMoonStarz/SAM/issues"
  },
  "author": "0xMoonStarz",
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["claude", "claude-code", "tokens", "compression", "mcp", "sam"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0"
  }
}
